--========================
-- 🌸 VISIBILITY CHECK
--========================

local function isVisible(part)
	local camera = Workspace.CurrentCamera
	local origin = camera.CFrame.Position
	local target = part.Position
	local rayParams = RaycastParams.new()
	rayParams.FilterType = Enum.RaycastFilterType.Exclude
	local ignoreList = {camera}
	local char = LocalPlayer.Character
	if char then table.insert(ignoreList, char) end
	rayParams.FilterDescendantsInstances = ignoreList
	local result = Workspace:Raycast(origin, target - origin, rayParams)
	if result then
		local hitInstance = result.Instance
		local targetModel = part.Parent
		local ancestor = hitInstance
		while ancestor do
			if ancestor == targetModel then return true end
			ancestor = ancestor.Parent
		end
		return false
	end
	return true
end

--========================
-- 🌸 MM2 ROLE DETECTION
--========================

-- MM2 stores role info in player GUI tags
local function getPlayerRole(player)
	-- Try to find role from PlayerGui or game tags
	local pg = player:FindFirstChildOfClass("PlayerGui")
	if pg then
		-- Common MM2 role check via leaderstats or tags
		local ls = player:FindFirstChild("leaderstats")
		if ls then
			local role = ls:FindFirstChild("Role") or ls:FindFirstChild("role")
			if role then return role.Value end
		end
	end
	-- Fallback: check backpack for knife/gun
	local backpack = player:FindFirstChildOfClass("Backpack") or (player.Character)
	if backpack then
		if backpack:FindFirstChild("Knife") or (player.Character and player.Character:FindFirstChild("Knife")) then
			return "Murderer"
		end
		if backpack:FindFirstChild("Sheriff") or backpack:FindFirstChild("Gun")
			or (player.Character and (player.Character:FindFirstChild("Sheriff") or player.Character:FindFirstChild("Gun"))) then
			return "Sheriff"
		end
	end
	return "Innocent"
end

local function getRoleColor(role)
	if role == "Murderer" then
		return Color3.fromRGB(murdererR, murdererG, murdererB)
	elseif role == "Sheriff" then
		return Color3.fromRGB(sheriffR, sheriffG, sheriffB)
	else
		return Color3.fromRGB(innocentR, innocentG, innocentB)
	end
end

