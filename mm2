local function loadSettings()
	local ok, raw = pcall(readfile, SETTINGS_FILE)
	if not ok or not raw or raw == "" then
		setStatus("No save file found", Color3.fromRGB(220, 180, 60))
		return false
	end
	local ok2, data = pcall(function() return HttpService:JSONDecode(raw) end)
	if not ok2 or type(data) ~= "table" then
		setStatus("Load failed: corrupt file", Color3.fromRGB(220, 80, 80))
		return false
	end

	-- Apply values (with safe defaults)
	espEnabled         = data.espEnabled         or false
	espVisCheckEnabled = data.espVisCheckEnabled  or false
	espTeamCheck       = data.espTeamCheck        or false
	r = data.r  or 255;  g = data.g  or 170;  b = data.b  or 200
	tr = data.tr or 50;  tg = data.tg or 150;  tb = data.tb or 255
	aimbotEnabled     = data.aimbotEnabled     or false
	aimbotFOV         = data.aimbotFOV         or 150
	aimbotSmoothing   = data.aimbotSmoothing   or 0.80
	aimbotExtraSmooth = data.aimbotExtraSmooth or 0
	aimbotPrediction  = data.aimbotPrediction  or 0
	aimbotPart        = data.aimbotPart        or "Head"
	triggerbotEnabled = data.triggerbotEnabled or false
	trigTeamCheck     = data.trigTeamCheck     or true
	trigDelay         = data.trigDelay         or 0
	trigDuration      = data.trigDuration      or 50
	MARK_RADIUS       = data.MARK_RADIUS       or 100
	savedKey          = data.savedKey          or nil

	-- Restore keybind
	if data.espKeyName then
		local kc = Enum.KeyCode[data.espKeyName]
		if kc then espKey = kc end
	end

	-- Sync all UI
	applySettings()
	setStatus("Loaded ✓", Color3.fromRGB(80, 220, 130))
	return true
end

local function resetSettings()
	-- Delete the file and restore code defaults
	pcall(deletefile, SETTINGS_FILE)
	espEnabled = false;  espVisCheckEnabled = false;  espTeamCheck = false
	r=255; g=170; b=200;  tr=50; tg=150; tb=255
	aimbotEnabled=false; aimbotFOV=150; aimbotSmoothing=0.80
	aimbotExtraSmooth=0; aimbotPrediction=0; aimbotPart="Head"
	triggerbotEnabled=false; trigTeamCheck=true
	trigDelay=0; trigDuration=50; MARK_RADIUS=100
	savedKey = nil
	espKey = Enum.KeyCode.Z
	applySettings()
	setStatus("Reset to defaults ✓", Color3.fromRGB(220, 140, 60))
end

-- Wire up buttons
SaveBtn.MouseButton1Click:Connect(saveSettings)
LoadBtn.MouseButton1Click:Connect(loadSettings)
ResetBtn.MouseButton1Click:Connect(resetSettings)

-- Auto-load on startup (after all UI is built)
task.spawn(function()
	task.wait(0.3)
	-- Try to load settings
	local loaded = loadSettings()
	if loaded then
		SetAutoLoadLabel.Text = "✓ Settings auto-loaded on inject"
	end

	-- After loading, check if we have a saved key and validate it silently
	if savedKey then
		local isValid, data = validateKey(savedKey)
		if isValid then
			hubAuthorized = true
			showGUI() -- Key is valid, open main menu directly
			return
		end
	end

	-- If we get here, they don't have a saved key OR it expired/is invalid
	hubAuthorized = false
	showKeyUI("Please enter your 48-hour key.", true)
end)
end -- end Aimbot + Triggerbot + Settings block
