local permanentTeammateSet    = {}   -- { [maleModel]   = true }  active-round fast check
local permanentTeammateNames   = {}   -- { [displayName]  = true }  survives respawns
local permanentTeammateUserIds = {}   -- { [userId]       = true }  most robust, never changes
local MARK_RADIUS = 100            -- studs; adjustable

-- Get our own world position from LocalPlayer.WorldModel.Male
local function getMyPosition()
	local wm = LocalPlayer:FindFirstChildOfClass("WorldModel")
	if not wm then return nil end
	for _, obj in ipairs(wm:GetChildren()) do
		if obj:IsA("Model") and obj.Name == "Male" then
			local root = obj:FindFirstChild("Root")
				or obj:FindFirstChild("HumanoidRootPart")
				or obj.PrimaryPart
			if root and root:IsA("BasePart") then return root.Position end
		end
	end
	return nil
end

