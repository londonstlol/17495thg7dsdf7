-- Triggerbot loop
connections[#connections + 1] = RunService.Heartbeat:Connect(function()
	if not hubAuthorized or not triggerbotEnabled or trigFiring then return end

	local cam = Workspace.CurrentCamera
	local rayParams = RaycastParams.new()
	rayParams.FilterType = Enum.RaycastFilterType.Exclude
	local ignoreList = { cam }
	local myChar = LocalPlayer.Character
	if myChar then table.insert(ignoreList, myChar) end
	local wm = LocalPlayer:FindFirstChildOfClass("WorldModel")
	if wm then table.insert(ignoreList, wm) end
	rayParams.FilterDescendantsInstances = ignoreList

	local result = Workspace:Raycast(cam.CFrame.Position, cam.CFrame.LookVector * 2000, rayParams)
	if not result then
		if TrigStatusLabel.Text ~= "Status: Idle" then
			TrigStatusLabel.Text = "Status: Idle"
			TrigStatusLabel.TextColor3 = Color3.fromRGB(130, 130, 140)
		end
		return
	end

	-- Walk up to find a Male model
	local hitModel = nil
	local ancestor = result.Instance
	while ancestor do
		if ancestor:IsA("Model") and ancestor.Name == "Male" then
			hitModel = ancestor
			break
		end
		ancestor = ancestor.Parent
	end

	if not hitModel then
		if TrigStatusLabel.Text ~= "Status: Idle" then
			TrigStatusLabel.Text = "Status: Idle"
			TrigStatusLabel.TextColor3 = Color3.fromRGB(130, 130, 140)
		end
		return
	end

	-- Must be alive
	local hum = hitModel:FindFirstChildOfClass("Humanoid")
	if not hum or hum.Health <= 0 then return end

	-- Skip ragdolls
	local bs = 0
	for _, d in pairs(hitModel:GetDescendants()) do
		if d:IsA("BallSocketConstraint") then bs += 1 end
	end
	if bs > 0 then return end

	-- Skip teammates if enabled
	if trigTeamCheck and isTeammate(hitModel) then
		TrigStatusLabel.Text = "Status: Teammate (skipped)"
		TrigStatusLabel.TextColor3 = Color3.fromRGB(tr, tg, tb)
		return
	end

	-- Fire!
	TrigStatusLabel.Text = "Status: Firing..."
	TrigStatusLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
	trigFiring = true

	task.spawn(function()
		if trigDelay > 0 then task.wait(trigDelay / 1000) end
		if triggerbotEnabled then
			pcall(mouse1press)
			task.wait(math.max(trigDuration, 10) / 1000)
			pcall(mouse1release)
		end
		task.wait(0.05)  -- small cooldown
		trigFiring = false
		TrigStatusLabel.Text = "Status: Idle"
		TrigStatusLabel.TextColor3 = Color3.fromRGB(130, 130, 140)
	end)
end)

