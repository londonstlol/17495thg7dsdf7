connections[#connections + 1] = RunService.Heartbeat:Connect(function()
	local color = Color3.fromRGB(r, g, b)
	Preview.BackgroundColor3 = color
	EnemyPreview.BackgroundColor3 = color
	BarTitle.TextColor3 = color
	-- Keep scrollbar color in sync
	Module.ScrollBarImageColor3 = color
	if activeTab then activeTab.btn.TextColor3 = color end

	-- ANTI-TAMPER: Ensure Aimbot & ESP refuse to work if hubAuthorized is false
	if not hubAuthorized then return end

	if not espEnabled then return end

	for _, obj in pairs(Workspace:GetChildren()) do
		if obj:IsA("Model") and obj.Name == "Male" then
			local highlight = obj:FindFirstChild("ESPHighlight")

			local bs = 0
			for _, d in pairs(obj:GetDescendants()) do
				if d:IsA("BallSocketConstraint") then bs += 1 end
			end
			if bs > 0 then
				if highlight then highlight:Destroy() end
				modelVisibility[obj] = nil
				continue
			end

			if not highlight then
				highlight = Instance.new("Highlight")
				highlight.Name = "ESPHighlight"
				highlight.FillTransparency = 0.4
				highlight.Parent = obj
			end

			local teammate = espTeamCheck and isTeammate(obj)
			local baseColor = teammate
				and Color3.fromRGB(tr, tg, tb)
				or color

			if espVisCheckEnabled then
				local targetPart = obj:FindFirstChild("HumanoidRootPart") or obj:FindFirstChild("UpperTorso") or obj:FindFirstChild("Head")
				local visible = targetPart and isVisible(targetPart) or false
				modelVisibility[obj] = visible

				if visible then
					highlight.FillColor    = baseColor
					highlight.OutlineColor = baseColor
				else
					if teammate then
						highlight.FillColor    = Color3.fromRGB(50, 80, 160)
						highlight.OutlineColor = Color3.fromRGB(50, 80, 160)
					else
						highlight.FillColor    = Color3.fromRGB(220, 50, 50)
						highlight.OutlineColor = Color3.fromRGB(220, 50, 50)
					end
				end
			else
				modelVisibility[obj] = true
				highlight.FillColor    = baseColor
				highlight.OutlineColor = baseColor
			end
		end
	end

	-- Also scan WorldModel for alive teammates/self and highlight them
	local wm = LocalPlayer:FindFirstChildOfClass("WorldModel")
	if wm and espTeamCheck then
		for _, obj in pairs(wm:GetChildren()) do
			if not (obj:IsA("Model") and obj.Name == "Male") then continue end

			local hum = obj:FindFirstChildOfClass("Humanoid")
			if not hum or hum.Health <= 0 then continue end  -- skip dead

			local bs = 0
			for _, d in pairs(obj:GetDescendants()) do
				if d:IsA("BallSocketConstraint") then bs += 1 end
			end
			if bs > 0 then continue end

			local highlight = obj:FindFirstChild("ESPHighlight")
			if not highlight then
				highlight = Instance.new("Highlight")
				highlight.Name = "ESPHighlight"
				highlight.FillTransparency = 0.4
				highlight.Parent = obj
			end

			-- WorldModel = teammate or self; color in teammate color
			local teamColor = Color3.fromRGB(tr, tg, tb)
			highlight.FillColor    = teamColor
			highlight.OutlineColor = teamColor
		end
	end
end)

