			activeSliderBar = Bar
			activeSliderCallback = function(rel)
				Fill.Size = UDim2.new(rel, 0, 1, 0)
				local val = math.floor(minVal + rel * (maxVal - minVal))
				ValLbl.Text = tostring(val)
				callback(val)
			end
		end
	end)

	return Fill, ValLbl
end

