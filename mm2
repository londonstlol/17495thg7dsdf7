	end
end)

connections[#connections+1] = UserInputService.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton2 then
		isAiming = false
		lockedTarget = nil
		accumX, accumY = 0, 0
		subPixX, subPixY = 0, 0
	end
end)

connections[#connections+1] = RunService.RenderStepped:Connect(function(dt)
	if not hubAuthorized then return end
	if not aimbotEnabled then return end
	if not isAiming then return end

	local target = lockedTarget
	if not target or not target.Parent then
		target = findClosestTarget()
		lockedTarget = target
	end
	if not target then return end

	local hrp = getHRP()
	local predOffset = Vector3.new(0, 0, 0)
	if aimbotPrediction > 0 and target.AssemblyLinearVelocity then
		predOffset = target.AssemblyLinearVelocity * aimbotPrediction
	end

	local worldPos = target.Position + predOffset
	local screenPos, onScreen = Camera:WorldToViewportPoint(worldPos)
	if not onScreen then lockedTarget = nil return end

	local vp = Camera.ViewportSize
	local center = Vector2.new(vp.X/2, vp.Y/2)
	local rawDeltaX = screenPos.X - center.X
	local rawDeltaY = screenPos.Y - center.Y

	local effectiveSpeed = math.clamp((1-aimbotSmoothing)*(1-aimbotExtraSmooth), 0.01, 1)
	local moveX = rawDeltaX * effectiveSpeed
	local moveY = rawDeltaY * effectiveSpeed

	subPixX = subPixX + moveX
	subPixY = subPixY + moveY

	local sendX = math.floor(math.abs(subPixX)+0.5) * math.sign(subPixX)
	local sendY = math.floor(math.abs(subPixY)+0.5) * math.sign(subPixY)

	if sendX ~= 0 or sendY ~= 0 then
		pcall(function() mousemoverel(sendX, sendY) end)
		subPixX = subPixX - sendX
		subPixY = subPixY - sendY
	end
end)

