local activeSliderCallback, activeSliderBar = nil, nil

connections[#connections + 1] = UserInputService.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		activeSliderCallback = nil
		activeSliderBar = nil
	end
end)

connections[#connections + 1] = UserInputService.InputChanged:Connect(function(input)
	if activeSliderCallback and activeSliderBar and input.UserInputType == Enum.UserInputType.MouseMovement then
		local relative = math.clamp((input.Position.X - activeSliderBar.AbsolutePosition.X) / activeSliderBar.AbsoluteSize.X, 0, 1)
		activeSliderCallback(relative)
	end
end)

local function createSlider(label, yPos, default, callback)
	local Text = Instance.new("TextLabel")
	Text.Size = UDim2.new(0, 30, 0, 20)
	Text.Position = UDim2.new(0, 20, 0, yPos)
	Text.BackgroundTransparency = 1
	Text.Text = label
	Text.TextColor3 = Color3.new(1, 1, 1)
	Text.Font = Enum.Font.Gotham
	Text.TextSize = 14
	Text.Parent = Module

	local Bar = Instance.new("Frame")
	Bar.Size = UDim2.new(0, 300, 0, 6)
	Bar.Position = UDim2.new(0, 60, 0, yPos + 7)
	Bar.BackgroundColor3 = Color3.fromRGB(70, 70, 70)
	Bar.Parent = Module
	Instance.new("UICorner", Bar).CornerRadius = UDim.new(1, 0)

	local Fill = Instance.new("Frame")
	Fill.Size = UDim2.new(default / 255, 0, 1, 0)
	Fill.BackgroundColor3 = Color3.fromRGB(r, g, b)
	Fill.Parent = Bar
	Instance.new("UICorner", Fill).CornerRadius = UDim.new(1, 0)

	Bar.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			activeSliderBar = Bar
			activeSliderCallback = function(relative)
				Fill.Size = UDim2.new(relative, 0, 1, 0)
				callback(math.floor(relative * 255))
			end
		end
	end)
end

