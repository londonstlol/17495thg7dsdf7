--========================
-- 🛡 GUI HARDENING
-- Three layers of protection:
--   1. ScreenGui lives in CoreGui — game scripts cannot touch it
--   2. Watch ScreenGui.AncestryChanged — if removed, immediately re-inject
--   3. Heartbeat watchdog — if Main hides while guiVisible=true, restore it
--========================

-- Layer 2: if anything removes or re-parents ScreenGui, put it straight back
ScreenGui.AncestryChanged:Connect(function(_, newParent)
	if newParent == nil then
		-- Destroyed — rebuild by re-parenting; CoreGui first, PlayerGui fallback
		task.wait()  -- one frame so Roblox finishes the destroy
		local ok = pcall(function() ScreenGui.Parent = game:GetService("CoreGui") end)
		if not ok then
			ScreenGui.Parent = LocalPlayer:WaitForChild("PlayerGui")
		end
	end
end)

-- Layer 3: restore Main if it gets hidden while the user wants it open
RunService.Heartbeat:Connect(function()
	if hubAuthorized and guiVisible and not Main.Visible then
		Main.Visible = true
		MainScale.Scale = 1
	end
end)

-- Also handle character respawn (clean up stale ESP highlights)
LocalPlayer.CharacterAdded:Connect(function(char)
	task.wait(0.3)
	-- Remove any highlights whose Adornee no longer exists
	for _, child in pairs(ScreenGui:GetChildren()) do
		if child:IsA("Highlight") and (not child.Adornee or not child.Adornee.Parent) then
			child:Destroy()
		end
		if child:IsA("BillboardGui") and (not child.Adornee or not child.Adornee.Parent) then
			child:Destroy()
		end
	end
	-- Reapply speed hack
	if speedHackEnabled then
		local hum = char:FindFirstChildOfClass("Humanoid")
		if hum then hum.WalkSpeed = speedHackValue end
	end
end)

--========================
-- 👁 EVENT-BASED ITEM ESP
-- Uses DescendantAdded instead of scanning every frame.
-- Tags items once when they appear; cleans up when removed.
--========================

local trackedItems = {}  -- [instance] = {billboard?, highlight?}

local function isGun(name)
	return name:find("sheriff") or name:find("gun") or name:find("revolver") or name:find("pistol")
end
local function isKnife(name)
	return name:find("knife") or name:find("blade")
end

-- Returns true only if this is the murderer's actual equipped knife Tool.
-- Cosmetic hip knives are plain Model/MeshPart decorations, NOT Tools.
-- The real murderer knife is a Tool inside a player Character or Backpack.
local function isMurdererKnifeTool(obj)
	if not obj:IsA("Tool") then return false end
	if not isKnife(obj.Name:lower()) then return false end
	for _, player in pairs(Players:GetPlayers()) do
		if player == LocalPlayer then continue end
		local char = player.Character
		local bp   = player:FindFirstChildOfClass("Backpack")
		if (char and obj:IsDescendantOf(char)) or (bp and obj:IsDescendantOf(bp)) then
			return true
		end
	end
	return false
end

local function isCoin(name)
	return name == "coin" or name:find("^coin") or name:find("coin$")
end

local function tagItem(obj)
	if trackedItems[obj] then return end  -- already tagged
	local name = obj.Name:lower()

	local labelText, labelColor

	if obj:IsA("Tool") and isGun(name) and gunESPEnabled then
		labelText  = "🔫 GUN"
		labelColor = Color3.fromRGB(50, 200, 255)
	elseif isMurdererKnifeTool(obj) and knifeESPEnabled then
		labelText  = "🔪 KNIFE"
		labelColor = Color3.fromRGB(255, 50, 50)
	elseif obj:IsA("BasePart") and isCoin(name) and coinESPEnabled then
		labelText  = "💰 ?"
		labelColor = Color3.fromRGB(255, 220, 50)
	else
		return  -- not something we care about
	end

	-- Find an anchor part to attach to
	local anchor = obj:IsA("BasePart") and obj or obj:FindFirstChildWhichIsA("BasePart")
	if not anchor then return end

	local bb = Instance.new("BillboardGui")
	bb.Name = "SakuraItemESP"
	bb.Size = UDim2.new(0, 90, 0, 22)
	bb.StudsOffset = Vector3.new(0, 2.5, 0)
	bb.AlwaysOnTop = true
	bb.Adornee = anchor   -- point at the part WITHOUT parenting to Workspace
	bb.Parent = ScreenGui  -- live in CoreGui, safe from anticheat

	local lbl = Instance.new("TextLabel", bb)
	lbl.Name = "ItemLabel"
	lbl.Size = UDim2.new(1, 0, 1, 0)
	lbl.BackgroundTransparency = 1
	lbl.Text = labelText
	lbl.TextColor3 = labelColor
	lbl.Font = Enum.Font.GothamBold
	lbl.TextSize = 13
	lbl.TextStrokeTransparency = 0

	trackedItems[obj] = {billboard = bb, label = lbl, anchor = anchor}

	-- Auto-clean when the item is removed from workspace
	obj.AncestryChanged:Connect(function()
		if not obj:IsDescendantOf(Workspace) then
			if bb and bb.Parent then bb:Destroy() end
			trackedItems[obj] = nil
		end
	end)
end

local function untagItem(obj)
	local t = trackedItems[obj]
	if t then
		if t.billboard and t.billboard.Parent then t.billboard:Destroy() end
		trackedItems[obj] = nil
	end
end

local function clearAllItemESP()
	for obj, t in pairs(trackedItems) do
		if t.billboard and t.billboard.Parent then t.billboard:Destroy() end
	end
	trackedItems = {}
	-- Also sweep for any orphaned tags
	for _, v in pairs(Workspace:GetDescendants()) do
		if v.Name == "SakuraItemESP" then v:Destroy() end
	end
end

-- Scan existing workspace items on toggle-on
local function scanExistingItems()
	for _, obj in pairs(Workspace:GetDescendants()) do
		tagItem(obj)
	end
end

-- Listen for new items appearing
connections[#connections+1] = Workspace.DescendantAdded:Connect(function(obj)
	tagItem(obj)
end)

-- When toggles change, rescan or clear
local _prevGun, _prevKnife, _prevCoin = false, false, false
connections[#connections+1] = RunService.Heartbeat:Connect(function()
	-- Handle toggle changes for item ESP
	if gunESPEnabled ~= _prevGun or knifeESPEnabled ~= _prevKnife or coinESPEnabled ~= _prevCoin then
		_prevGun   = gunESPEnabled
		_prevKnife = knifeESPEnabled
		_prevCoin  = coinESPEnabled
		-- Remove tags for newly-disabled types, rescan for newly-enabled
		for obj, t in pairs(trackedItems) do
			local name = obj.Name:lower()
			if obj:IsA("Tool") and isGun(name) and not gunESPEnabled then untagItem(obj)
			elseif isMurdererKnifeTool(obj) and not knifeESPEnabled then untagItem(obj)
			elseif obj:IsA("BasePart") and isCoin(name) and not coinESPEnabled then untagItem(obj)
			end
		end
		if gunESPEnabled or knifeESPEnabled or coinESPEnabled then
			scanExistingItems()
		end
	end
end)

-- Coin distance update — only runs when coin ESP is on, only touches labeled coins (no scanning)
local _coinTimer = 0
connections[#connections+1] = RunService.Heartbeat:Connect(function(dt)
	if not coinESPEnabled then return end
	_coinTimer = _coinTimer + dt
	if _coinTimer < 0.5 then return end  -- update every 0.5s, not every frame
	_coinTimer = 0
	local myHRP = getHRP()
	if not myHRP then return end
	for obj, t in pairs(trackedItems) do
		if obj:IsA("BasePart") and isCoin(obj.Name:lower()) and t.label and t.label.Parent then
			local dist = math.floor((obj.Position - myHRP.Position).Magnitude)
			t.label.Text = "💰 " .. dist .. "m"
		end
	end
end)

