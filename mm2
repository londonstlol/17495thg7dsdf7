		local char = player.Character
		if not char then continue end
		local hrp = char:FindFirstChild("HumanoidRootPart")
		local hum = char:FindFirstChildOfClass("Humanoid")
		if not hrp or not hum or hum.Health <= 0 then continue end

		local role = getPlayerRole(player)
		local roleColor = getRoleColor(role)

		-- Player highlight
		-- IMPORTANT: Parent to ScreenGui (CoreGui), NOT to char in Workspace.
		-- Parenting to char triggers MM2's anticheat which wipes PlayerGui.
		-- Instead we use Adornee to point the Highlight at the char remotely.
		local hlName = "SakuraESP_" .. player.UserId
		if espEnabled then
			local hl = ScreenGui:FindFirstChild(hlName)
			if not hl then
				hl = Instance.new("Highlight")
				hl.Name = hlName
				hl.Adornee = char
				hl.Parent = ScreenGui
			else
				hl.Adornee = char  -- re-point in case char changed (respawn)
			end
			local finalColor = roleESPEnabled and roleColor or accentColor
			if espVisCheck then
				local vis = isVisible(hrp)
				hl.FillColor    = vis and finalColor or Color3.fromRGB(220, 50, 50)
				hl.OutlineColor = vis and finalColor or Color3.fromRGB(220, 50, 50)
			else
				hl.FillColor    = finalColor
				hl.OutlineColor = finalColor
			end
			hl.FillTransparency = 0.4
		else
			local hl = ScreenGui:FindFirstChild(hlName)
			if hl then hl:Destroy() end
		end

		-- Role Label
		-- Also parented to ScreenGui (not hrp) to avoid anticheat triggers.
		local bbName = "SakuraRole_" .. player.UserId
		if roleESPEnabled then
			local bb = ScreenGui:FindFirstChild(bbName)
			if not bb then
				bb = Instance.new("BillboardGui")
				bb.Name = bbName
				bb.Size = UDim2.new(0, 100, 0, 30)
				bb.StudsOffset = Vector3.new(0, 3, 0)
				bb.AlwaysOnTop = true
				bb.Adornee = hrp
				bb.Parent = ScreenGui
				local lbl = Instance.new("TextLabel", bb)
				lbl.Size = UDim2.new(1, 0, 1, 0)
				lbl.BackgroundTransparency = 1
				lbl.Font = Enum.Font.GothamBold
				lbl.TextSize = 14
				lbl.TextStrokeTransparency = 0
				lbl.Name = "RoleLabel"
			else
				bb.Adornee = hrp  -- re-point after respawn
			end
			local lbl = bb:FindFirstChild("RoleLabel")
			if lbl then
				lbl.Text = role
				lbl.TextColor3 = roleColor
			end
		else
			local bb = ScreenGui:FindFirstChild(bbName)
			if bb then bb:Destroy() end
		end
	end

	-- FOV Circle
	FOVCircle.Visible = aimbotEnabled
	if aimbotEnabled then
		local vp = Camera.ViewportSize
		FOVCircle.Position = Vector2.new(vp.X/2, vp.Y/2)
		FOVCircle.Radius = aimbotFOV
	end
end)

