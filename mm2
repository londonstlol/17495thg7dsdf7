local KEY_URL          = "https://raw.githubusercontent.com/londonstlol/Keys/refs/heads/main/Sakura%20keys"
local MONETIZATION_URL = "https://lootdest.org/s?wk0dkIjV"
local KEY_LIFETIME     = 172800  -- 48 hours

local function getExternalSecret()
	local success, result = pcall(function()
		return game:HttpGetAsync(KEY_URL)
	end)
	if success and result and #result > 0 then
		return result:gsub("%s+", "")
	end
	return nil
end

local function validateKey(key)
	if not key or type(key) ~= "string" or key == "" then return false, "Please enter a key" end
	local tHex, hHex = key:match("^SAKURA%-(%x%x%x%x%x%x%x%x)%-(%x%x%x%x%x%x)$")
	if not tHex then return false, "Invalid key format" end
	local createdAt   = tonumber(tHex, 16)
	local claimedHash = tonumber(hHex, 16)
	local currentSecret = getExternalSecret()
	if not currentSecret then return false, "Could not contact key server. Try again later." end
	local combined = currentSecret .. tostring(createdAt)
	local hash = 0
	for i = 1, #combined do
		hash = (hash * 31 + combined:byte(i)) % 16777216
	end
	if hash ~= claimedHash then return false, "Invalid key (Bad Hash)" end
	local age = os.time() - createdAt
	if age < 0           then return false, "Key not yet valid (Time out of sync)" end
	if age > KEY_LIFETIME then return false, "Key has expired (48 hours passed)" end
	return true, KEY_LIFETIME - age
end

local function fmtTime(secs)
	local h = math.floor(secs / 3600)
	local m = math.floor((secs % 3600) / 60)
	return string.format("%dh %dm", h, m)
end

