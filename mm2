local Camera = Workspace.CurrentCamera
local lockedTarget = nil
local accumX,  accumY  = 0, 0   -- EMA smoother (velocity estimate only)
local subPixX, subPixY = 0, 0   -- sub-pixel remainder (what sendX/Y is subtracted from)

connections[#connections + 1] = RunService.Heartbeat:Connect(function()
	if not hubAuthorized or not isAiming then
		lockedTarget = nil
		return
	end

	if lockedTarget then
		local hum = lockedTarget.Parent and lockedTarget.Parent:FindFirstChildOfClass("Humanoid")
		local bs = 0
		if lockedTarget.Parent then
			for _, d in pairs(lockedTarget.Parent:GetDescendants()) do
				if d:IsA("BallSocketConstraint") then bs += 1 end
			end
		end
		if not hum or hum.Health <= 0 or bs > 0 or not lockedTarget.Parent then
			lockedTarget = nil
		elseif espVisCheckEnabled and not isVisible(lockedTarget) then
			lockedTarget = nil
		else
			return
		end
	end

	local screenCenter = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
	local closest, closestDist = nil, aimbotFOV

	for _, obj in pairs(Workspace:GetChildren()) do
		if obj:IsA("Model") and obj.Name == "Male" then
			local part = obj:FindFirstChild(aimbotPart)
			local hum = obj:FindFirstChildOfClass("Humanoid")
			local bs = 0
			for _, d in pairs(obj:GetDescendants()) do
				if d:IsA("BallSocketConstraint") then bs += 1 end
			end

			if part and hum and hum.Health > 0 and bs == 0 then
				if espTeamCheck and isTeammate(obj) then continue end
				if espVisCheckEnabled then
					if not isVisible(part) then continue end
				end
				local sp, onScreen = Camera:WorldToViewportPoint(part.Position)
				if onScreen then
					local dist = (Vector2.new(sp.X, sp.Y) - screenCenter).Magnitude
					if dist < closestDist then
						closestDist = dist
						closest = part
					end
				end
			end
		end
	end

	lockedTarget = closest
end)

RunService:BindToRenderStep("SakuraAimbot", 2000, function(dt)
	if not hubAuthorized or not aimbotEnabled or not isAiming or not lockedTarget then
		subPixX, subPixY = 0, 0
		return
	end

	local aimPos
	if aimbotPart == "Head" then
		local fc = lockedTarget:FindFirstChild("FaceCenterAttachment")
		aimPos = fc and fc.WorldPosition
			or lockedTarget.Position + Vector3.new(0, lockedTarget.Size.Y * 0.5, 0)
	else
		aimPos = lockedTarget.Position
	end

	local hrp = lockedTarget.Parent and lockedTarget.Parent:FindFirstChild("HumanoidRootPart")
	local vel = hrp and hrp:IsA("BasePart") and hrp.AssemblyLinearVelocity or Vector3.zero
	aimPos = aimPos + vel * aimbotPrediction

	local screenPos, onScreen = Camera:WorldToViewportPoint(aimPos)
	if not onScreen then
		subPixX, subPixY = 0, 0
		return
	end

	local screenCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
	local rawDeltaX    = screenPos.X - screenCenter.X
	local rawDeltaY    = screenPos.Y - screenCenter.Y

	-- Stateless proportional control: no EMA, no memory.
	-- Both sliders combine into one factor so there is no accumulation
	-- that could create oscillation or circling.
	--   aimbotSmoothing  0→1 : lower = faster (speed slider)
	--   aimbotExtraSmooth 0→1: lower = faster (additional damping)
	-- effectiveSpeed is always in (0, 1] so we can never overshoot rawDelta.
	local effectiveSpeed = math.clamp(
		(1 - aimbotSmoothing) * (1 - aimbotExtraSmooth),
		0.01, 1
	)

	-- Desired move this frame: a fraction of remaining delta
	local moveX = rawDeltaX * effectiveSpeed
	local moveY = rawDeltaY * effectiveSpeed

	-- Sub-pixel accumulation so fractional moves aren't lost at high FPS
	subPixX = subPixX + moveX
	subPixY = subPixY + moveY

	local sendX = math.floor(math.abs(subPixX) + 0.5) * math.sign(subPixX)
	local sendY = math.floor(math.abs(subPixY) + 0.5) * math.sign(subPixY)

	if sendX ~= 0 or sendY ~= 0 then
		pcall(function() mousemoverel(sendX, sendY) end)
		subPixX = subPixX - sendX
		subPixY = subPixY - sendY
	end
end)

