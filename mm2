			Circle:TweenPosition(UDim2.new(0, 2, 0.5, -10), "Out", "Quad", 0.15, true)
		end
	end

	refresh()

	BG.MouseButton1Click:Connect(function()
		state = not state
		refresh()
		onChange(state)
	end)

	return BG, Circle, function() return state end, function(v) state = v refresh() end
end

