-- Legacy helper: find the Player who owns a model via plr.Character
local function getOwnerPlayer(model)
	for _, plr in pairs(Players:GetPlayers()) do
		local char = plr.Character
		if not char then continue end
		if char == model then return plr end
		local ancestor = model.Parent
		while ancestor do
			if ancestor == char then return plr end
			ancestor = ancestor.Parent
		end
	end
	return nil
end

local function isTeammate(model)
	-- 1) Fast instance check (works during the same round)
	if permanentTeammateSet[model] then return true end

	local hum = model:FindFirstChildOfClass("Humanoid")
	local dn  = hum and hum.DisplayName or ""

	-- 2) Display-name check (survives respawn once the name is set)
	if dn ~= "" and permanentTeammateNames[dn] then
		return true
	end

	-- 3) UserId check via player lookup (survives respawn + async name lag)
	if dn ~= "" and next(permanentTeammateUserIds) then
		for _, plr in pairs(Players:GetPlayers()) do
			if permanentTeammateUserIds[plr.UserId] then
				if plr.DisplayName == dn or plr.Name == dn then
					return true
				end
			end
		end
	end

	-- 4) Fallback: standard Roblox Teams / plr.Character (other games)
	local owner = getOwnerPlayer(model)
	if owner then
		if owner == LocalPlayer then return true end
		if LocalPlayer.Team ~= nil and owner.Team == LocalPlayer.Team then return true end
		return false
	end

	return false
end

