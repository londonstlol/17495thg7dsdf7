-- ══════════════════════════════════════════════════════════════════════════
-- AUTO TEAM MARK  —  cluster-proximity based round detection
--
-- Works for both game modes (5v5 and 2v2):
--   • Round START  → all players cluster together; TagInterface then shows
--                    teammates (4 in 5v5, 1 in 2v2) — that's when we mark.
--   • Round END    → all players teleport to their own spawn (spread apart).
--
-- Logic:
--   1. Count alive Male models within CLUSTER_RADIUS of us.
--   2. When >= CLUSTER_MIN are nearby AND TagInterface has entries → mark once.
--      (CLUSTER_MIN=1 so even a single nearby male in 2v2 satisfies the check;
--       the TagInterface is the real "teams assigned" gate.)
--   3. After marking, once 0 males have been nearby for DISPERSE_SECS seconds
--      → reset so the next round can auto-mark again.
-- ══════════════════════════════════════════════════════════════════════════
local CLUSTER_RADIUS  = MARK_RADIUS   -- studs  (default 100, user-adjustable)
local CLUSTER_MIN     = 1             -- 1 nearby male is enough (works for 2v2 and 5v5)
local DISPERSE_SECS   = 5             -- seconds of dispersal before resetting

local markedThisRound = false
local dispersedSince  = nil           -- tick() when we last had 0 nearby, or nil

connections[#connections + 1] = RunService.Heartbeat:Connect(function()
	if not espTeamCheck then return end

	local myPos = getMyPosition()
	if not myPos then return end

	-- ── count nearby alive males ───────────────────────────────────────────
	local nearbyModels = {}
	for _, obj in pairs(Workspace:GetChildren()) do
		if not (obj:IsA("Model") and obj.Name == "Male") then continue end
		local root = obj:FindFirstChild("Root")
			or obj:FindFirstChild("HumanoidRootPart")
			or obj.PrimaryPart
		if not (root and root:IsA("BasePart")) then continue end
		-- skip ragdolls
		local isRagdoll = false
		for _, d in pairs(obj:GetDescendants()) do
			if d:IsA("BallSocketConstraint") then isRagdoll = true; break end
		end
		if isRagdoll then continue end
		if (root.Position - myPos).Magnitude <= CLUSTER_RADIUS then
			table.insert(nearbyModels, obj)
		end
	end

	local nearbyCount = #nearbyModels

	-- ── dispersal timer (round-reset detection) ────────────────────────────
	if nearbyCount == 0 then
		if dispersedSince == nil then
			dispersedSince = tick()
		elseif markedThisRound and (tick() - dispersedSince) >= DISPERSE_SECS then
			-- Players have been scattered long enough → round is over → reset
			permanentTeammateSet = {}
			markedThisRound = false
			dispersedSince  = nil
			MarkTeamCount.Text = "Waiting for next round..."
		end
		return
	end

	-- Players are nearby → reset dispersal timer
	dispersedSince = nil

	if markedThisRound then return end   -- already marked this round, hold

	if nearbyCount < CLUSTER_MIN then return end   -- not enough clustered yet

	-- ── clustered! wait for TagInterface to confirm teams are assigned ─────
	local entries = getTagTeammates()
	if not entries then return end   -- pre-round countdown; teams not assigned yet

	-- Store names/UserIds immediately — no position needed, works as fallback
	-- even if the distance-match below hasn't fired yet.
	-- Re-clear each attempt so stale entries from a prior failed attempt don't linger.
	permanentTeammateNames   = {}
	permanentTeammateUserIds = {}
	for _, entry in ipairs(entries) do
		if #entry.name > 0 then
			permanentTeammateNames[entry.name] = true
			for _, plr in pairs(Players:GetPlayers()) do
				if plr ~= LocalPlayer
					and (plr.Name == entry.name or plr.DisplayName == entry.name) then
					permanentTeammateUserIds[plr.UserId] = true
				end
			end
		end
	end

	-- Distance-match synchronously RIGHT NOW.
	-- entries.distStuds and myPos are from the SAME frame, so they agree.
	-- If we waited (task.spawn), myPos would have moved but distStuds wouldn't
	-- — causing mismatches half the time.
	local matched    = matchTagToModels(entries, myPos)
	local matchCount = 0
	for _ in pairs(matched) do matchCount += 1 end

	if matchCount > 0 then
		-- Good match — lock for this round.
		markedThisRound  = true
		permanentTeammateSet = {}
		for model in pairs(matched) do
			permanentTeammateSet[model] = true
		end
		MarkTeamCount.Text = matchCount .. " teammate"
			.. (matchCount == 1 and "" or "s") .. " auto-detected"
	else
		-- Positions not settled yet — DON'T lock markedThisRound.
		-- Next Heartbeat will retry until it gets at least one match.
		-- Names are already saved above, so the fallback works immediately.
		MarkTeamCount.Text = "Teams detected — finding models..."
	end
end)


